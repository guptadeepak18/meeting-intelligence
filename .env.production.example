# Production environment template for Meeting Intelligence
# Copy this file to your secret manager or hosting provider settings.
# Do not commit real values.

# Runtime
NODE_ENV=production
API_PORT=4000

# Database (managed Postgres recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/meeting_intelligence?schema=public

# Clerk
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_JWT_ISSUER=https://your-tenant.clerk.accounts.dev

# Storage (Vercel Blob or equivalent)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=meeting-intelligence

# AI providers
HF_API_KEY=your_huggingface_api_key_here
HF_ASR_MODEL=openai/whisper-small
HF_LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# Security
WEBHOOK_SECRET=replace-with-strong-random-value
ENCRYPTION_KEY=replace-with-32-byte-minimum-random-value

# Web to API routing
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com/api/v1

# Development fallback headers in web app
# Keep these empty in production unless you intentionally run with fallback mode.
NEXT_PUBLIC_DEV_USER_ID=
NEXT_PUBLIC_DEV_ORG_ID=
NEXT_PUBLIC_DEV_ROLE=
NEXT_PUBLIC_DEV_TEAM_ID=

# Notification automation
NOTIFICATION_DISPATCH_ENABLED=true
NOTIFICATION_DISPATCH_CRON=*/5 * * * *
SCHEDULER_USER_ID=44444444-4444-4444-8444-444444444444
SCHEDULER_ORG_ID=11111111-1111-4111-8111-111111111111
SCHEDULER_TEAM_ID=22222222-2222-4222-8222-222222222221

# Notification providers (choose one or more)
# Option A: SMTP
SMTP_HOST=smtp.your-provider.com
SMTP_FROM=noreply@your-domain.com

# Option B: SendGrid or Resend keys if wired in deployment
SENDGRID_API_KEY=
RESEND_API_KEY=

# Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
