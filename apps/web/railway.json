{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --prod=false && pnpm --filter @meeting-intelligence/web build"
  },
  "deploy": {
    "startCommand": "cd apps/web && node_modules/.bin/next start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
